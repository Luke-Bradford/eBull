            <repPdEnd>2025-12-31</repPdEnd>
            <filedAt>2026-02-26</filedAt>
        </genInfo>
        <invstOrSecs>
            <invstOrSec>
                <name>APPLE INC</name>
                <cusip>037833100</cusip>

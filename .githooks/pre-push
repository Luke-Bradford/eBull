# fixtures must supply is_tradable" gate from tests/fixtures/ to the
# whole tree. ~50ms; no docker / DB / Python dependency.
echo "==> Pre-push gate: INSERT INTO instruments lint"
bash scripts/check_instruments_inserts.sh


POSTGRES_DB=ebull
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=5432

APP_ENV=dev
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ebull

# eToro API credentials are now stored encrypted via the Settings UI
# (broker_credentials table). See scripts/migrate_etoro_credential.py
# for migrating from the old env-var approach.
ETORO_ENV=demo

# Companies House — UK filing documents (SEC EDGAR needs no key)
COMPANIES_HOUSE_API_KEY=

# SEC EDGAR — no API key, but fair-use policy requires a User-Agent
# with a contact email. SEC rejects requests with placeholder domains
# (example.com, noreply@*) and any UA missing an email address — 403
# Forbidden on /Archives/edgar/daily-index/. Use any real reachable
# email; a Gmail +tag alias works fine.
#
# Format (SEC spec): "Project/org name <contact-email@domain>"
# Default in app/config.py is a placeholder that SEC rejects.
SEC_USER_AGENT=eBull self-hosted <your-email+ebull@example-real-domain.com>

DEFAULT_PORTFOLIO_MODE=balanced
MAX_ACTIVE_POSITIONS=20
MAX_INITIAL_POSITION_PCT=5
MAX_FULL_POSITION_PCT=10
MAX_SECTOR_EXPOSURE_PCT=25

ENABLE_AUTO_TRADING=false
ENABLE_LIVE_TRADING=false

# --- Operator auth (issue #98) ----------------------------------------
# Service token used by tests / scripts / cron / curl. Must be at least
# 32 chars. Leave unset in dev if you only use the browser session path.
# Renamed from EBULL_API_KEY in #98 -- update any old deploys.
EBULL_SERVICE_TOKEN=

# Browser session settings. session_cookie_secure MUST be true in any
# deployment served over HTTPS; default false here so the local HTTP
# dev stack works without TLS.
EBULL_SESSION_COOKIE_SECURE=false
EBULL_SESSION_ABSOLUTE_TIMEOUT_HOURS=12
EBULL_SESSION_IDLE_TIMEOUT_MINUTES=60

# --- First-run setup + bind address (issue #106 / ADR 0002) -----------
# Bind address for the FastAPI server. The default 127.0.0.1 keeps the
# instance loopback-only -- in that mode the first-run /setup flow does
# not require a bootstrap token (Mode A). Change to 0.0.0.0 (or any
# non-loopback address) ONLY if you also set EBULL_BOOTSTRAP_TOKEN, or
# if you want the server to generate one and print it to the log on
# first start (Mode B). The login surface is open to anyone who can
# reach the bind address -- there is no IP allow-list.
EBULL_HOST=127.0.0.1

# Optional. If set, the value is required as the setup_token field on
# POST /auth/setup, regardless of bind address. Use a high-entropy
# random string (32+ chars). Leave unset to fall back to the bind-mode
# rules above.
EBULL_BOOTSTRAP_TOKEN=

# --- Broker secret encryption (issue #99 / ADR 0001) ------------------
# Base64-encoded 32-byte key used to encrypt broker credentials
# (broker_credentials.ciphertext, AES-256-GCM). The server REFUSES TO
# START if this is missing or does not decode to exactly 32 bytes --
# we never silently generate a key, because that would lock existing
# ciphertext rows out on the next restart. Rotation is manual; see
# ADR 0001. Generate a fresh value with:
#   python -c "import os, base64; print(base64.b64encode(os.urandom(32)).decode())"
EBULL_SECRETS_KEY=
